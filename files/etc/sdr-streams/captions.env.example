# /etc/sdr-streams/captions.env
# Configuration for the caption orchestrator (Whisper + lyrics).

# Local Icecast stream URL (the orchestrator decodes this back to PCM)
ICECAST_URL=http://localhost:8000/fm.mp3

# Remote Whisper FastAPI service running on a GPU host
WHISPER_URL=http://gpu-host.example.com:8088
WHISPER_TOKEN=PASTE_WHISPER_TOKEN_FROM_GPU_HOST

# AcoustID API key (free signup at https://acoustid.org/login)
# Used as fallback when RDS doesn't provide artist/title
ACOUSTID_KEY=PASTE_YOUR_ACOUSTID_KEY

# State files (writable; created by RuntimeDirectory= in the unit)
STATE_PATH=/run/sdr-streams/captions.json
NOW_PLAYING_PATH=/run/sdr-streams/now_playing.json

# Lyric timing offsets (milliseconds). Tune these per-station after listening.
# RDS_OFFSET_MS positive = lyrics jump ahead (compensates for late RDS announce)
# LRC_OFFSET_MS negative = lyrics start later (used for AcoustID-fingerprint matches)
RDS_OFFSET_MS=5000
LRC_OFFSET_MS=-6000
