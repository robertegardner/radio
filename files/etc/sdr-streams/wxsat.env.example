# /etc/sdr-streams/wxsat.env
# Configuration for the weather-satellite (Meteor-M LRPT) scheduler + capture.
# Read by wxsat-scheduler.service (EnvironmentFile). The real file is gitignored.
#
# NOTE: systemd's EnvironmentFile only treats '#' as a comment at the START of
# a line. Do NOT put inline "# ..." after a value — it becomes part of the value.

# --- Satellites (1=enabled, 0=disabled) ---
# Meteor-M2-4 is the live LRPT bird. Meteor-M2-3 is in storage mode (off).
M2_4_ENABLED=1
M2_3_ENABLED=0

# --- Observer QTH (Cape Girardeau, MO) ---
LAT=37.31
LON=-89.55
ALT_KM=0.1

# --- Pass selection ---
# MIN_ELEV_DEG: skip passes whose max elevation is below this.
# PREDICT_HOURS: how far ahead to predict.
MIN_ELEV_DEG=20
PREDICT_HOURS=48

# --- TLE source ---
# celestrak.org is UNREACHABLE from this Pi (verified Phase 0). Use a source
# that actually resolves+connects. {norad} is substituted per satellite.
# TLE_TTL_HOURS: reuse cached TLEs newer than this before re-fetching.
TLE_URL_TEMPLATE=https://tle.ivanstanojevic.me/api/tle/{norad}
TLE_TTL_HOURS=12

# --- Capture (RF) ---
# SatDump's Debian build has NO SoapySDR source, so we capture with rx_sdr
# (rx_tools) on the dx-R2 Port B and decode the baseband with SatDump.
# dx-R2 valid rates only: ...250000 500000 768000 1000000 2000000 2048000...
# (1024000 is NOT supported). 1.0 Msps is ample for 72k LRPT (~150 kHz wide)
# and keeps the recorded IQ small (~4 MB/s; a 15-min pass ~3.6 GB, deleted
# after decode). Raise toward 2048000 only if a wider window helps.
# LRPT_PIPELINE: meteor_m2-x_lrpt (72k). Use meteor_m2-x_lrpt_80k if M2-4 is 80k.
FREQ_MHZ=137.9
ANTENNA="Antenna B"
SAMPLERATE=1000000
GAIN=40
LRPT_PIPELINE=meteor_m2-x_lrpt

# --- Scheduler timing (seconds) ---
# AOS_BUFFER_S: start the capture this many seconds before AOS.
# POST_LOS_S: keep capturing this many seconds after LOS.
AOS_BUFFER_S=45
POST_LOS_S=15
REFRESH_INTERVAL_S=1800

# --- Safety / mode ---
# DRY_RUN=1 (Phase 1): run the loop + listener check, record decisions, but
# NEVER touch the SDR. Set to 0 (Phase 2) to enable real captures.
# WXSAT_MIN_FREE_GB: prune oldest captures when free space drops below this.
DRY_RUN=1
WXSAT_MIN_FREE_GB=2
