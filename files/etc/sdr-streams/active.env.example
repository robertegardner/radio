# /etc/sdr-streams/active.env
# Written by the Flask UI on every /tune. This file is the seed value
# loaded at boot. Set ICECAST_PASS to match the source password from your
# Icecast configuration.
MODE=wbfm
FREQ=101.1M
SAMP=200000
GAIN=30
BITRATE=128k
MOUNT=fm.mp3
EXTRA_FLAGS=""
ICECAST_PASS=CHANGE_ME_TO_MATCH_ICECAST_XML
