# /etc/sdr-streams/mux.env
# Configuration for FM-multistation mode (iq_capture + channel pipelines).
# Read by sdr-iq-capture.service and channel_pipeline.sh. The real file is
# gitignored. systemd EnvironmentFile: '#' starts a comment only at line start —
# do NOT put inline "# ..." after a value.
#
# FM-multistation mode is mutually exclusive with sdr-fm@active (legacy mono),
# AM tuning, and the wxsat capture — the dx-R2 opens for exactly one process.
# Rollback to known-good mono is always:
#   sudo systemctl stop sdr-mux sdr-iq-capture && sudo systemctl start sdr-fm@active

# --- Capture front end (dx-R2 Antenna A = Shakespeare 5120, FM only) ---
# CENTER_MHZ: tune center. 98.0 = midpoint of the wanted set.
# FS: capture sample rate. 8 Msps -> +/-4 MHz (94-102 captured); keeps the
#     advertised window's edges out of the ADC/anti-alias rolloff.
# IF_BW: SDRplay IF bandwidth, matched to FS.
# GAIN: SoapySDR overall-gain abstraction. Capturing the WHOLE band raises
#       aggregate ADC power vs single-station, so watch the startup ADC-fill log
#       and mux_status.json adc_peak_pct: keep the strongest local well under
#       100% (invariant 5 — visible overload is a Phase 1 stop). Do NOT engage
#       the FM-band notch; it kills the band we want.
CENTER_MHZ=98.0
FS=8000000
IF_BW=8000000
ANTENNA="Antenna A"
DECIM=32
# Gain: prefer explicit dx-R2 elements over the overall GAIN knob. IFGR = IF gain
# reduction [20..59]; RFGR = RF gain reduction / LNA state [0..27]; higher = MORE
# attenuation for both. The whole-band capture overloads the front end unless RFGR
# attenuates the LNA: RFGR=9 cleared it (ADC peak ~49%, rms ~25%) on the Shakespeare
# antenna (gain_probe.py 2026-06-09). RFGR is the overload lever; lower IFGR for
# more level on weak stations. GAIN (overall) is the fallback if these are unset.
GAIN=40
GAIN_RFGR=9
GAIN_IFGR=40

# --- Advertised tuning window (stations outside are not tunable in this mode) ---
# 95.0-101.0 MHz: KGMO 100.7 sits at +2.7 of +/-4.0 (67% Nyquist, clean);
# 95.7 at -2.3. The UI greys out anything outside this window.
WINDOW_LO_MHZ=95.0
WINDOW_HI_MHZ=101.0

# --- IQ fanout socket ---
IQ_SOCKET=/run/sdr-streams/iq.sock

# --- Stereo decode tuning (channel_pipeline.sh -> stereo_decode.py) ---
# STEREO_SCALE: output gain on matrixed L/R before int16. csdr fmdemod output is
#   small; set so out_peak (stereo_decode stderr) rides ~0.5-0.9 without clipping.
# STEREO_PILOT_FLOOR: pilot RMS at/below which a channel is forced fully mono
#   (honesty gate, invariant 4); blend ramps to full stereo by ~3x this.
# MONO_SCALE: ffmpeg volume gain for mono channels (same role as STEREO_SCALE).
STEREO_SCALE=3.0
STEREO_PILOT_FLOOR=0.003
MONO_SCALE=4.0

# --- Phase 1: single hardcoded channel (no channels.json yet) ---
# Streamed to a TEST mount, never /fm.mp3, so legacy mono stays the default.
PHASE1_FREQ_MHZ=100.7
PHASE1_MOUNT=test.mp3
PHASE1_STEREO=1
PHASE1_BITRATE=192k
PHASE1_RDS=0
