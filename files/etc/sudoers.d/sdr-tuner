# /etc/sudoers.d/sdr-tuner
# Allow the radio user to control sdr-* services without a password.
# Validate after install: sudo visudo -cf /etc/sudoers.d/sdr-tuner
radio ALL=(root) NOPASSWD: /usr/bin/systemctl restart sdr-fm@active
radio ALL=(root) NOPASSWD: /usr/bin/systemctl stop    sdr-fm@active
radio ALL=(root) NOPASSWD: /usr/bin/systemctl start   sdr-fm@active
radio ALL=(root) NOPASSWD: /usr/bin/systemctl start   sdr-scan.service
radio ALL=(root) NOPASSWD: /usr/bin/systemctl start   sdr-am-scan.service
radio ALL=(root) NOPASSWD: /usr/bin/systemctl restart sdr-captions
# FM-multistation mode (iq_capture + mux). Mutually exclusive with sdr-fm@active.
radio ALL=(root) NOPASSWD: /usr/bin/systemctl start   sdr-iq-capture
radio ALL=(root) NOPASSWD: /usr/bin/systemctl stop    sdr-iq-capture
radio ALL=(root) NOPASSWD: /usr/bin/systemctl restart sdr-iq-capture
radio ALL=(root) NOPASSWD: /usr/bin/systemctl start   sdr-mux
radio ALL=(root) NOPASSWD: /usr/bin/systemctl stop    sdr-mux
radio ALL=(root) NOPASSWD: /usr/bin/systemctl restart sdr-mux
# V2 (2026-06-14 cutover): the dx-R2 is served to the rack by sdr-source@dx-r2.
# wxsat_capture.sh must stop it to borrow the device for a pass, then restart it.
radio ALL=(root) NOPASSWD: /usr/bin/systemctl stop    sdr-source@dx-r2
radio ALL=(root) NOPASSWD: /usr/bin/systemctl start   sdr-source@dx-r2
radio ALL=(root) NOPASSWD: /usr/bin/systemctl restart sdr-source@dx-r2
